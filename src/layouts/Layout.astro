---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  keywords?: string;
}

const { title, description, keywords } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={canonical.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical.href} />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="logo" href={`${base}`}>能量站 Nengliang</a>
        <nav class="nav anchor-nav" aria-label="主导航">
          <a href={`${base}`}>首页</a>
          <a href={`${base}#price`}>价格</a>
          <a href={`${base}#steps`}>步骤</a>
          <a href={`${base}#address`}>收款地址</a>
          <a href={`${base}help/what-is-energy/`}>什么是能量</a>
          <a href={`${base}help/trc20-transfer-fee/`}>TRC20 手续费</a>
          <a href={`${base}about/`}>关于我们</a>
          <a href={`${base}contact/`}>联系</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <nav aria-label="页脚">
        <a href={`${base}privacy/`}>隐私政策</a>
        <a href={`${base}terms/`}>使用条款</a>
        <a href={`${base}contact/`}>联系我们</a>
      </nav>
      <p>© {new Date().getFullYear()} 能量站 · 建站模板请按实际业务修改文案与资质信息</p>
    </footer>
  </body>
</html>
