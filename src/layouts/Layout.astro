---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  keywords?: string;
}

const { title, description, keywords } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={canonical.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical.href} />
    <meta name="baidu-site-verification" content="codeva-rxdw3OFkD0" />
  </head>
  <body class="bg-gray-950 text-gray-100 antialiased">
    <header class="sticky top-0 z-50 border-b border-gray-800 bg-gray-950/90 backdrop-blur-sm">
      <div class="container flex flex-col sm:flex-row h-auto sm:h-16 items-center justify-between py-3 sm:py-0">
        <a class="text-xl font-bold text-blue-400 hover:text-blue-500 mb-2 sm:mb-0" href={`${base}`}>TRX25</a>
        <nav class="flex flex-wrap justify-center sm:justify-end gap-x-4 gap-y-2 text-sm font-medium" aria-label="主导航">
          <a class="text-gray-400 hover:text-blue-400" href={`${base}`}>首页</a>
          <a class="text-gray-400 hover:text-blue-400" href={`${base}#price`}>价格</a>
          <a class="text-gray-400 hover:text-blue-400" href={`${base}#steps`}>步骤</a>
          <a class="text-gray-400 hover:text-blue-400" href={`${base}#address`}>收款地址</a>
          <a class="text-gray-400 hover:text-blue-400" href={`${base}help/what-is-energy/`}>能量是什么</a>
          <a class="text-gray-400 hover:text-blue-400" href={`${base}help/trc20-transfer-fee/`}>手续费</a>
          <a class="text-gray-400 hover:text-blue-400" href={`${base}about/`}>关于我们</a>
          <a class="text-gray-400 hover:text-blue-400" href={`${base}contact/`}>联系</a>
        </nav>
      </div>
    </header>
    <main class="container py-8 md:py-16">
      <slot />
    </main>
    <footer class="border-t border-gray-800 bg-gray-950 py-8 text-center text-sm text-gray-400">
      <nav class="mb-4 flex flex-wrap justify-center space-x-4" aria-label="页脚">
        <a class="text-gray-400 hover:text-blue-400" href={`${base}privacy/`}>隐私政策</a>
        <a class="text-gray-400 hover:text-blue-400" href={`${base}terms/`}>使用条款</a>
        <a class="text-gray-400 hover:text-blue-400" href={`${base}contact/`}>联系我们</a>
      </nav>
      <p>© {new Date().getFullYear()} TRX25 · 建站模板请按实际业务修改文案与资质信息</p>
    </footer>
  </body>
</html>
