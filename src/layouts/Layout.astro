---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  keywords?: string;
}

const { title, description, keywords } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={canonical.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical.href} />
    <meta name="baidu-site-verification" content="codeva-rxdw3OFkD0" />
    <meta name="theme-color" content="#030712" />
  </head>
  <body class="bg-[#030712] text-gray-100 antialiased min-h-screen flex flex-col selection:bg-blue-500/30 selection:text-blue-200 font-sans">
    <!-- 顶部渐变光晕背景 -->
    <div class="fixed inset-0 z-[-1] pointer-events-none">
      <div class="absolute top-[-20%] left-[-10%] w-[50%] h-[50%] rounded-full bg-blue-900/20 blur-[120px]"></div>
      <div class="absolute bottom-[-20%] right-[-10%] w-[50%] h-[50%] rounded-full bg-indigo-900/10 blur-[120px]"></div>
    </div>

    <header class="sticky top-0 z-50 border-b border-white/5 bg-[#030712]/80 backdrop-blur-xl supports-[backdrop-filter]:bg-[#030712]/60">
      <div class="container flex flex-col sm:flex-row h-auto sm:h-20 items-center justify-between py-4 sm:py-0">
        <a class="text-2xl font-black tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-400 hover:from-blue-300 hover:to-indigo-300 transition-all mb-3 sm:mb-0" href={`${base}`}>
          TRX25<span class="text-blue-500">.</span>
        </a>
        <nav class="flex flex-wrap justify-center sm:justify-end gap-x-6 gap-y-3 text-sm font-medium" aria-label="主导航">
          <a class="text-gray-400 hover:text-white transition-colors" href={`${base}`}>首页</a>
          <a class="text-gray-400 hover:text-white transition-colors" href={`${base}#price`}>价格</a>
          <a class="text-gray-400 hover:text-white transition-colors" href={`${base}#steps`}>流程</a>
          <a class="text-gray-400 hover:text-white transition-colors" href={`${base}#address`}>租用地址</a>
          <a class="text-gray-400 hover:text-white transition-colors" href={`${base}help/what-is-energy/`}>帮助</a>
        </nav>
      </div>
    </header>
    
    <main class="flex-grow container py-12 md:py-20 lg:py-24">
      <slot />
    </main>

    <footer class="border-t border-white/5 bg-[#030712] py-12 mt-auto">
      <div class="container flex flex-col md:flex-row items-center justify-between gap-6 text-sm text-gray-500">
        <div class="flex items-center gap-2">
          <span class="font-bold text-gray-300">TRX25</span>
          <span>© {new Date().getFullYear()} All rights reserved.</span>
        </div>
        <nav class="flex flex-wrap justify-center gap-x-6 gap-y-2" aria-label="页脚">
          <a class="hover:text-gray-300 transition-colors" href={`${base}help/what-is-energy/`}>什么是能量</a>
          <a class="hover:text-gray-300 transition-colors" href={`${base}help/trc20-transfer-fee/`}>手续费说明</a>
          <a class="hover:text-gray-300 transition-colors" href={`${base}privacy/`}>隐私政策</a>
          <a class="hover:text-gray-300 transition-colors" href={`${base}terms/`}>使用条款</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
