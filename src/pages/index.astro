---
import Layout from "../layouts/Layout.astro";
import {
  TRON_RECEIVER_ADDRESS,
  TRONSCAN_ADDRESS_URL,
  PRICE_WITH_U,
  PRICE_WITHOUT_U,
  SITE_TAGLINE,
} from "../config/site";

const base = import.meta.env.BASE_URL;
---

<Layout
  title={`【官方】TRX能量租赁平台 - ${PRICE_WITH_U}/${PRICE_WITHOUT_U} TRX/笔，波场TRON转账省80%手续费`}
  description={`专业波场TRX能量租赁平台，USDT(TRC20)转账有U地址仅需${PRICE_WITH_U} TRX，无U地址${PRICE_WITHOUT_U} TRX。即时自动到账，安全可靠，大幅降低您的链上交易成本。`}
  keywords="TRX能量租赁,波场能量租赁,TRON能量租赁,USDT转账手续费,TRC20能量,波场TRX,能量闪租,TRX25"
>
  <section id="price" class="flex flex-col items-center justify-center py-8 md:py-16 text-center border-b border-gray-800 mb-8 md:mb-12">
    <p class="text-sm md:text-base text-gray-400 uppercase tracking-wider mb-2">即时到账 · 极速省钱</p>
    <h1 id="price-title" class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold leading-tight text-transparent bg-clip-text bg-gradient-to-r from-blue-300 via-blue-400 to-blue-500">
      {PRICE_WITH_U} / {PRICE_WITHOUT_U}<span class="text-xl md:text-2xl font-medium text-gray-400 block sm:inline-block sm:ml-2 sm:mt-0"> TRX / 笔</span>
    </h1>
    <p class="mt-4 text-base md:text-lg text-gray-300 max-w-2xl">
      USDT(TRC20)转账手续费立省最高 80%，全自动即时派发。
    </p>
  </section>

  <section aria-labelledby="sec-plans" class="mb-8 md:mb-12">
    <h2 id="sec-plans" class="section-heading">价格说明</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
      <div class="bg-gray-800 border border-blue-500 rounded-xl p-6 text-center shadow-lg">
        <div class="text-xs text-gray-400 mb-2">对方地址已有 U</div>
        <div class="text-3xl font-bold text-blue-400">{PRICE_WITH_U} TRX</div>
        <div class="mt-2 text-sm text-gray-400">常规单笔 USDT 转账能量，<br class="sm:hidden" />立省手续费！</div>
      </div>
      <div class="bg-gray-800 border border-gray-700 rounded-xl p-6 text-center">
        <div class="text-xs text-gray-400 mb-2">对方地址无 U</div>
        <div class="text-3xl font-bold text-gray-100">{PRICE_WITHOUT_U} TRX</div>
        <div class="mt-2 text-sm text-gray-400">新地址或无 USDT 余额，<br class="sm:hidden" />首次转账更推荐此项。</div>
      </div>
      <div class="bg-gray-800 border border-gray-700 rounded-xl p-6 text-center">
        <div class="text-xs text-gray-400 mb-2">到账方式</div>
        <div class="text-3xl font-bold text-gray-100">自动</div>
        <div class="mt-2 text-sm text-gray-400">全天候 AI 智能派发，<br class="sm:hidden" />极速无感。</div>
      </div>
    </div>
  </section>

  <section aria-labelledby="sec-advantages" class="mb-8 md:mb-12">
    <h2 id="sec-advantages" class="section-heading">为什么选择能量站？</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
      <div class="bg-gray-800 border border-gray-700 rounded-xl p-6 text-center">
        <h3 class="text-lg font-semibold mb-2">🚀 极速到账</h3>
        <p class="text-sm text-gray-400">链上确认后即时派发，告别漫长等待。</p>
      </div>
      <div class="bg-gray-800 border border-gray-700 rounded-xl p-6 text-center">
        <h3 class="text-lg font-semibold mb-2">💰 成本优化</h3>
        <p class="text-sm text-gray-400">按需租赁，大幅降低您的 TRX 转账成本。</p>
      </div>
      <div class="bg-gray-800 border border-gray-700 rounded-xl p-6 text-center">
        <h3 class="text-lg font-semibold mb-2">🛡️ 安全可靠</h3>
        <p class="text-sm text-gray-400">所有交易链上可查，地址公示透明，无私钥风险。</p>
      </div>
      <div class="bg-gray-800 border border-gray-700 rounded-xl p-6 text-center">
        <h3 class="text-lg font-semibold mb-2">🤖 全自动处理</h3>
        <p class="text-sm text-gray-400">AI 智能监控，无需人工干预，24/7 全天候服务。</p>
      </div>
    </div>
  </section>

  <section id="steps" aria-labelledby="sec-steps" class="mb-8 md:mb-12">
    <h2 id="sec-steps" class="section-heading">简单 3 步，轻松获取能量</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
      <div class="flex items-start bg-gray-800 border border-gray-700 rounded-xl p-6">
        <span class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-500/20 text-blue-400 font-bold flex items-center justify-center mr-4">1</span>
        <div>
          <h3 class="text-lg font-semibold mb-1">复制收款地址</h3>
          <p class="text-sm text-gray-400">复制本页收款地址，务必确认网络为 <strong>TRON</strong>。</p>
        </div>
      </div>
      <div class="flex items-start bg-gray-800 border border-gray-700 rounded-xl p-6">
        <span class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-500/20 text-blue-400 font-bold flex items-center justify-center mr-4">2</span>
        <div>
          <h3 class="text-lg font-semibold mb-1">按情况转入 {PRICE_WITH_U} 或 {PRICE_WITHOUT_U} TRX</h3>
          <p class="text-sm text-gray-400">对方地址有 U 转 ${PRICE_WITH_U} TRX，无 U 转 ${PRICE_WITHOUT_U} TRX。不确定时，按无 U 价格转账更稳妥。</p>
        </div>
      </div>
      <div class="flex items-start bg-gray-800 border border-gray-700 rounded-xl p-6">
        <span class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-500/20 text-blue-400 font-bold flex items-center justify-center mr-4">3</span>
        <div>
          <h3 class="text-lg font-semibold mb-1">等待能量到账</h3>
          <p class="text-sm text-gray-400">链上确认后即时自动到账，高峰期或有少量延迟。</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-8 md:mb-12" id="address" aria-labelledby="sec-address">
    <div class="bg-gray-800 border border-gray-700 rounded-xl p-6 text-center shadow-lg">
      <h2 id="sec-address" class="section-heading mb-4">收款地址（TRX / TRON 网络）</h2>
      <div class="max-w-xl mx-auto mb-4">
        <div class="font-mono text-base md:text-lg lg:text-xl bg-gray-900 border border-gray-700 rounded-md p-4 break-all text-blue-400 selection:bg-blue-800 selection:text-white" id="tron-address" translate="no">
          {TRON_RECEIVER_ADDRESS}
        </div>
        <p class="mt-3 text-sm text-gray-400">
          **只转 TRX！** 务必确认网络是 <strong>TRON</strong>。转账前请务必核对地址和金额。
        </p>
      </div>
      <div class="flex flex-wrap justify-center gap-4">
        <button type="button" class="btn btn-secondary px-6 py-3 text-base md:text-lg" id="copy-address-btn">
          复制地址
        </button>
        <a
          class="btn btn-secondary px-6 py-3 text-base md:text-lg"
          href={TRONSCAN_ADDRESS_URL}
          target="_blank"
          rel="noopener noreferrer"
        >
          TronScan 查询 →
        </a>
      </div>
    </div>
  </section>

  <section aria-labelledby="sec-faq" class="mb-8 md:mb-12">
    <h2 id="sec-faq" class="section-heading">常见问题解答</h2>
    <div class="max-w-3xl mx-auto faq-list">
      <details class="faq-item">
        <summary>Q：为什么能量租赁有两种价格？</summary>
        <p>
          A：波场网络规则决定，接收方地址若无 USDT 余额或首次激活，消耗能量会更高。我们提供两种价格覆盖不同场景，确保您的转账成本最优。
        </p>
      </details>
      <details class="faq-item">
        <summary>Q：怎么判断对方地址是否「有 U」？</summary>
        <p>A：简单来说，如果对方地址从未收到过 USDT (TRC20) 或当前余额为零，可视为「无 U」地址。最准确的方法是前往 TronScan.org 查询该地址的 USDT 余额或历史交易记录。</p>
      </details>
      <details class="faq-item">
        <summary>Q：转账到收款地址后，能量多久能到账？</summary>
        <p>A：我们的系统全自动监控，通常在您的 TRX 转账完成后，等待 1-3 个区块确认（约 3-9 秒），能量即可自动派发到您发起转账的钱包地址。网络拥堵时可能略有延迟，但请放心，系统会确保处理。</p>
      </details>
      <details class="faq-item">
        <summary>Q：如果我转错了金额或转到了错误的链怎么办？</summary>
        <p>A：波场 (TRON) 链上交易具有**不可逆性**。一旦转账完成，资金将无法追回。请务必在转账前仔细核对收款地址、转账网络（必须是 TRON）以及转账金额。**切勿将资金转入其他区块链网络或非本页公示的地址。**</p>
      </details>
      <details class="faq-item">
        <summary>Q：能量租赁安全吗？我的私钥会不会泄露？</summary>
        <p>A：能量站是一个去中心化的租赁服务平台，您全程只需将 TRX 转账到我们的公开收款地址，**无需提供任何私钥、助记词或授权。** 所有交易都在链上公开透明，安全可靠。请务必保护好您的个人钱包信息。</p>
      </details>
      <details class="faq-item">
        <summary>Q：能量租赁能节省多少手续费？</summary>
        <p>A：通过租赁能量，您可以避免在 TRC20 转账时因能量不足而燃烧 TRX。以一笔标准 TRC20 转账为例，如果没有能量，可能需要燃烧约 13.5 TRX (当接收方有 U) 或更高。通过我们的服务，您仅需支付 ${PRICE_WITH_U} 或 ${PRICE_WITHOUT_U} TRX，**最高可节省约 80% 的手续费**。</p>
      </details>
      <details class="faq-item">
        <summary>Q：我可以使用哪个钱包进行操作？</summary>
        <p>A：您可以使用任何支持 TRON (波场) 网络和 TRC20 代币的去中心化钱包，例如 TronLink, TokenPocket, imToken, SafePal 等。**请勿直接从交易所转账 TRX 到我们的收款地址**，以免系统无法识别您的能量需求并自动派发。</p>
      </details>
    </div>
  </section>

  <section aria-labelledby="sec-seo" class="mb-8 md:mb-12">
    <h2 id="sec-seo" class="section-heading">延伸阅读</h2>
    <p class="mt-4 text-center text-gray-400">
      帮助搜索引擎与用户理解能量与手续费。
    </p>
    <ul class="mt-4 flex flex-wrap justify-center space-x-4 text-gray-400">
      <li><a class="hover:text-blue-400" href={`${base}help/what-is-energy/`}>波场「能量」是什么？</a></li>
      <li><a class="hover:text-blue-400" href={`${base}help/trc20-transfer-fee/`}>TRC20 手续费说明</a></li>
      <li><a class="hover:text-blue-400" href={`${base}about/`}>关于能量站</a></li>
    </ul>
  </section>

  <p class="note p-4 rounded-lg bg-yellow-900/20 border border-yellow-800 text-yellow-300 text-sm text-center mb-8 md:mb-12 max-w-4xl mx-auto">
    <strong>风险提示：</strong>链上操作不可逆，请务必核对收款地址和网络。本站仅为能量租赁服务，不构成任何投资或金融建议。正式经营请务必补充合规主体信息及法律声明。
  </p>

  <script define:vars={{ tronAddr: TRON_RECEIVER_ADDRESS }}>
    (function () {
      var btn = document.getElementById("copy-address-btn");
      if (!btn) return;
      btn.addEventListener("click", function () {
        function ok() {
          var t = btn.textContent;
          btn.textContent = "已复制";
          setTimeout(function () {
            btn.textContent = t;
          }, 2000);
        }
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(tronAddr).then(ok).catch(function () {
            window.prompt("请手动复制：", tronAddr);
          });
        } else {
          window.prompt("请手动复制：", tronAddr);
        }
      });
    })();
  </script>
</Layout>

<style>
  /* 自定义样式，确保 Tailwind 未覆盖的部分或特殊组件样式 */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* 确保链接和文本在小屏下居中 */
  @media (max-width: 640px) {
    .price-hero__sub,
    .btn-row {
      text-align: center;
      justify-content: center;
    }
    .btn-row .btn,
    .btn-row .btn-secondary {
      width: 100%;
    }
  }
</style>
